# shellcheck configuration for zsh-unplugged-minimal
# See: https://github.com/koalaman/shcheck/wiki/Directive

# This project uses both bash (setup.sh, env.zsh) and zsh scripts
# Some bash-specific features are intentional

# Allow sourcing without specifying path
# SC1090: Can't follow non-constant source
# SC1091: Not following source
source_path=zsh_functions

# Disable warnings for intentional patterns

# SC2034: Unused variables (many are used in other files)
disable=2034

# SC2154: Referenced but not assigned (set by caller)
disable=2154

# SC2155: Declare and assign separately (common in shell scripts)
disable=2155

# SC2230: 'which' is non-standard (used for compatibility)
disable=2230

# For bash scripts that work with both bash and zsh
# SC2312: Consider invoking command with eval
# (intentional for conditional execution)
disable=2312

# External sources
# SC1090 - Cannot follow source file
# SC1091 - Not following source
external-sources=true
